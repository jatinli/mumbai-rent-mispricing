{
  "name": "rentlens-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RentLens v1 frontend — Horizon, Living Map, Dossier, Verdict (aggregates-only public contract)",
  "scripts": {
    "dev": "next dev",
    "tokens": "tsx scripts/build-tokens.ts",
    "validate:contract": "tsx scripts/validate-contract.ts",
    "prebuild": "pnpm tokens && pnpm validate:contract",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "dependencies": {
    "@number-flow/react": "^0.5.5",
    "framer-motion": "^11.15.0",
    "geist": "^1.3.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@size-limit/preset-app": "^11.1.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
